{
  "name": "@linky/core",
  "version": "0.0.0",
  "description": "Effect-based domain logic and protocol workflows for Linky.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@effect/platform": "^0.96.1",
    "@noble/ciphers": "^2.1.1",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@scure/base": "^2.0.0",
    "@scure/bip32": "^2.0.1",
    "@scure/bip39": "^2.0.1",
    "effect": "^3.21.3"
  },
  "devDependencies": {
    "@linky/config": "workspace:*",
    "eslint": "^9.39.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.8"
  }
}
